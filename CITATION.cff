    affiliation: "Desert Research Institute"
    email: sayantan.majumdar@dri.edu
repository-code: "https://github.com/montimaj/iwv-bcm-et-eval"
license: MIT
keywords:
  - evapotranspiration
  - remote sensing
  - Indian Wells Valley
  - Great Basin
  - BCM
  - USGS Reitz ET
  - OpenET
  - MODIS
  - SSEBop
  - PML
